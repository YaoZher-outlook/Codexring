{
  "name": "codexring",
  "productName": "Codexring",
  "version": "0.1.0",
  "description": "A responsive always-on-top Codex status and usage widget for Windows.",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "node scripts/start-dev.cjs",
    "build": "tsc --noEmit && electron-vite build",
    "typecheck": "tsc --noEmit",
    "check": "npm run test && npm run build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "schemas:codex": "codex app-server generate-ts --out src/generated/codex"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^42.4.0",
    "electron-vite": "^3.0.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vitest": "^3.0.5"
  }
}
